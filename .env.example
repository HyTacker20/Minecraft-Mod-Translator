# AI Provider Configuration for Translation
# Copy this file to .env and add your API keys for your chosen provider(s).
# LiteLLM is used as the unified backend — it auto-detects providers from env vars.
#
# Supported providers and their model strings:
#   openai           → uses OPENAI_API_KEY
#   anthropic        → uses ANTHROPIC_API_KEY
#   gemini           → uses GEMINI_API_KEY
#   ollama           → uses OLLAMA_API_BASE (local)
#   litellm          → generic — pass any litellm-compatible model string
#   openaicompatible → uses OPENAICOMPATIBLE_API_KEY + OPENAICOMPATIBLE_BASE_URL

# Default translation model (used for any AI provider via LiteLLM)
TRANSLATION_MODEL=gpt-4o-mini

# Provider API keys (only set the ones you intend to use)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_API_BASE=http://localhost:11434

# OpenAI-Compatible provider (any OpenAI-compatible API: vLLM, LM Studio, OpenRouter, etc.)
OPENAICOMPATIBLE_API_KEY=your_api_key_here
OPENAICOMPATIBLE_BASE_URL=http://localhost:8080/v1
OPENAICOMPATIBLE_MODEL=gpt-4o-mini
