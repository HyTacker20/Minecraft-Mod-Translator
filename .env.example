# AI Provider Configuration for Translation
# Copy this file to .env and add your API keys for your chosen provider(s).
# LiteLLM is used as the unified backend — it auto-detects providers from env vars.
#
# Supported providers and their model strings:
#   openai     → uses OPENAI_API_KEY (model: gpt-4o-mini, gpt-3.5-turbo, etc.)
#   anthropic  → uses ANTHROPIC_API_KEY (model: claude-3-haiku, claude-3-opus, etc.)
#   gemini     → uses GEMINI_API_KEY (model: gemini/gemini-1.5-flash, gemini/gemini-1.5-pro)
#   ollama     → uses OLLAMA_API_BASE (model: ollama/llama3, ollama/mistral, etc.)
#   litellm    → generic — pass any litellm-compatible model string

# Default translation model (used for any AI provider via LiteLLM)
TRANSLATION_MODEL=gpt-4o-mini

# Provider API keys (only set the ones you intend to use)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_API_BASE=http://localhost:11434
